# ==============================
# BorrowTime — переменные окружения
# Скопируйте в .env и заполните значения
# ==============================

# --- HTTP ---
HTTP_ADDR=:8080
HTTP_READ_TIMEOUT=15
HTTP_WRITE_TIMEOUT=60

# --- Приложение ---
BASE_URL=http://localhost:8080

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=borrowtime
POSTGRES_PASSWORD=secret
POSTGRES_DB=borrowtime
POSTGRES_SSLMODE=disable
# Или полный DSN (перекрывает отдельные переменные):
# POSTGRES_DSN=postgres://borrowtime:secret@postgres:5432/borrowtime?sslmode=disable

# --- Redis ---
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# --- MinIO (S3-совместимое хранилище файлов) ---
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=borrowtime
MINIO_USE_SSL=false
